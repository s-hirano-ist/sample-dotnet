{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "TodoService": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "TodoDatabase": "Data Source=todo.db"
  },
  "Database": {
    "Provider": "Sqlite",
    "ApplyMigrations": false
  },
  "Authentication": {
    "Permissions": [
      "todo:write"
    ]
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ],
    "AllowedMethods": [
      "GET",
      "POST",
      "PUT",
      "DELETE"
    ],
    "AllowedHeaders": [
      "Content-Type",
      "X-API-Key",
      "X-Request-Id",
      "Idempotency-Key"
    ]
  },
  "RateLimit": {
    "Store": "Memory",
    "PermitLimit": 10,
    "WindowSeconds": 10
  },
  "Idempotency": {
    "Store": "Memory",
    "WaitTimeoutSeconds": 5,
    "EntryLifetimeSeconds": 300
  },
  "OpenTelemetry": {
    "Enabled": false,
    "OtlpEndpoint": "http://localhost:4317"
  },
  "AllowedHosts": "*"
}
