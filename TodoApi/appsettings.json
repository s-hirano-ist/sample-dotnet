{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "TodoService": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "TodoDatabase": "Data Source=todo.db"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ],
    "AllowedMethods": [
      "GET",
      "POST",
      "PUT",
      "DELETE"
    ],
    "AllowedHeaders": [
      "Content-Type",
      "X-API-Key",
      "X-Request-Id"
    ]
  },
  "RateLimit": {
    "Store": "Memory",
    "PermitLimit": 10,
    "WindowSeconds": 10
  },
  "AllowedHosts": "*"
}
