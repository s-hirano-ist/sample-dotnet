{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "TodoService": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "TodoDatabase": "Data Source=todo.db"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "RateLimit": {
    "PermitLimit": 10,
    "WindowSeconds": 10
  },
  "AllowedHosts": "*"
}
